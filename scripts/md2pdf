#!/usr/bin/env bash
set -euo pipefail

# Convert Markdown to PDF using pandoc + xelatex, with the ENSFont family.
# Deployed to ~/bin/md2pdf during Converge.
#
# Usage: md2pdf <input.md> [output.pdf]
#   - output defaults to <input>.pdf next to the source.

MAIN_FONT="ENS Font"
CJK_FONT="ENS Font"
MONO_FONT="ENS Font Mono"

if [[ $# -lt 1 || $# -gt 2 ]]; then
    echo "usage: md2pdf <input.md> [output.pdf]" >&2
    exit 64
fi

input=$1
output=${2:-"${input%.*}.pdf"}

for tool in pandoc xelatex; do
    if ! command -v "$tool" &>/dev/null; then
        echo "error: $tool not found in PATH." >&2
        echo "  install with: brew install pandoc && brew install --cask mactex-no-gui" >&2
        exit 127
    fi
done

if [[ ! -f $input ]]; then
    echo "error: input not found: $input" >&2
    exit 66
fi

pandoc "$input" \
    --pdf-engine=xelatex \
    -V mainfont="$MAIN_FONT" \
    -V CJKmainfont="$CJK_FONT" \
    -V monofont="$MONO_FONT" \
    -V geometry:margin=1in \
    -o "$output"

echo "wrote $output"
