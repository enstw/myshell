#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: $0 <pdf-file|directory> [output-dir]"
    exit 1
fi

SOURCE="$1"
# Capture if an output dir was actually provided
PROVIDED_OUTDIR="${2:-}"

convert_file() {
    local INFILE="$1"
    local TARGET_OUTDIR="$2"
    
    # If no output dir was provided, use the directory of the input file
    if [ -z "$TARGET_OUTDIR" ]; then
        TARGET_OUTDIR="$(cd "$(dirname "$INFILE")" && pwd)"
    fi

    mkdir -p "$TARGET_OUTDIR"
    
    local BASENAME="$(basename "$INFILE" | sed 's/\.[^.]*$//')"
    local OUTPUT="$TARGET_OUTDIR/${BASENAME}.md"
    
    echo "Converting $INFILE using pymupdf4llm..."
    python3 -c "
import sys
import pymupdf4llm
try:
    md_text = pymupdf4llm.to_markdown('$INFILE')
    with open('$OUTPUT', 'w', encoding='utf-8') as f:
        f.write(md_text)
    print(f'Done: $OUTPUT')
except Exception as e:
    print(f'Error converting $INFILE: {e}', file=sys.stderr)
    sys.exit(1)
"
}

if [ -f "$SOURCE" ]; then
    if [[ "$SOURCE" == *.pdf ]]; then
        convert_file "$SOURCE" "$PROVIDED_OUTDIR"
    else
        echo "Error: $SOURCE is not a PDF file"
        exit 1
    fi
elif [ -d "$SOURCE" ]; then
    echo "Processing directory: $SOURCE"
    # Get absolute path of source dir
    ABS_SOURCE="$(cd "$SOURCE" && pwd)"
    for f in "$ABS_SOURCE"/*.pdf; do
        if [ -e "$f" ]; then
            convert_file "$f" "$PROVIDED_OUTDIR"
        fi
    done
else
    echo "Error: $SOURCE not found"
    exit 1
fi
