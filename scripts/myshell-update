#!/usr/bin/env bash
set -euo pipefail

# Update all installed package managers, plugins, and clean up.
# Deployed to ~/bin/myshell-update by scripts/install; invoked via the
# `u` alias. The namespaced name avoids clobbering any personal
# ~/bin/update the user may already have.

echo "==> Updating system packages..."

if command -v brew &>/dev/null; then
    brew update
    brew upgrade
    brew cleanup
fi

if command -v apt &>/dev/null; then
    sudo apt update
    sudo apt upgrade -y
    sudo apt autoremove -y
fi

if command -v snap &>/dev/null; then
    sudo snap refresh
fi

# zinit
if command -v zinit &>/dev/null; then
    echo "==> Updating zinit plugins..."
    zsh -ic 'zinit self-update; zinit update --all'
fi

# pnpm — self-update, refresh the Node LTS runtime, and update global packages.
if command -v pnpm &>/dev/null; then
    echo "==> Updating pnpm..."
    pnpm self-update || true
    echo "==> Refreshing Node LTS (pnpm env)..."
    pnpm env use --global lts || true
    echo "==> Updating pnpm global packages..."
    pnpm update -g || true
fi

# Claude Code
if command -v claude &>/dev/null; then
    echo "==> Upgrading Claude Code..."
    claude upgrade
fi

# OpenCode — standalone binary, self-updates via its own command.
if command -v opencode &>/dev/null; then
    echo "==> Upgrading OpenCode..."
    opencode upgrade || true
fi

# Antigravity CLI (agy) — standalone binary, self-updates via its own command.
if command -v agy &>/dev/null; then
    echo "==> Updating Antigravity CLI (agy)..."
    agy update || true
fi

# Claude Code gstack skill — use the skill's own updater (same as /gstack-upgrade).
if [ -x "$HOME/.claude/skills/gstack/bin/gstack-update-check" ]; then
    echo "==> Updating Claude gstack skill..."
    "$HOME/.claude/skills/gstack/bin/gstack-update-check" --force || true
fi

echo "==> Done."
