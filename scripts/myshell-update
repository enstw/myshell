#!/usr/bin/env bash
set -euo pipefail

# Update all installed package managers, plugins, and clean up.
# Deployed to ~/bin/myshell-update by scripts/install; invoked via the
# `u` alias. The namespaced name avoids clobbering any personal
# ~/bin/update the user may already have.
#
# Sections are independent and fail soft (`|| warn`): one flaky updater
# must not abort the rest — this is a convenience sweep, not a transaction.
# Warnings are counted and reported in the final Done line.

# Output vocabulary — deliberately duplicated byte-identical in ../bootstrap
# and ./install (this file is deployed standalone to ~/bin, so no sourced
# lib can reach all three); drift between the copies is a bug.
WARNINGS=0
log()    { printf '\n==> %s\n' "$*"; }
sublog() { printf '    %s\n' "$*"; }
warn()   { printf 'warning: %s\n' "$*" >&2; WARNINGS=$((WARNINGS+1)); }
die()    { printf 'error: %s\n' "$*" >&2; exit 1; }
trap 'rc=$?; printf "error: failed at line %s: %s (exit %s)\n" "$LINENO" "$BASH_COMMAND" "$rc" >&2; exit "$rc"' ERR

# sudo shim — same convention as bootstrap: root needs no prefix; non-root
# without sudo skips system-level updates (user-level ones still run).
if [[ $EUID -eq 0 ]]; then
    SUDO=""
    NO_SUDO=0
elif command -v sudo >/dev/null 2>&1; then
    SUDO=sudo
    NO_SUDO=0
else
    SUDO=""
    NO_SUDO=1
fi

if command -v brew &>/dev/null; then
    log "Updating Homebrew packages..."
    brew update || warn "brew update failed"
    brew upgrade || warn "brew upgrade failed"
    brew cleanup || warn "brew cleanup failed"
fi

if command -v apt &>/dev/null; then
    if [[ "$NO_SUDO" == "1" ]]; then
        warn "no sudo — skipping apt updates"
    else
        log "Updating apt packages..."
        $SUDO apt update || warn "apt update failed"
        $SUDO apt upgrade -y || warn "apt upgrade failed"
        $SUDO apt autoremove -y || warn "apt autoremove failed"
    fi
fi

if command -v snap &>/dev/null; then
    if [[ "$NO_SUDO" == "1" ]]; then
        warn "no sudo — skipping snap refresh"
    else
        log "Refreshing snaps..."
        $SUDO snap refresh || warn "snap refresh failed"
    fi
fi

# zinit is a zsh *function*, not a binary — `command -v zinit` is always
# false in bash — so key on its install dir instead.
ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
if [[ -f "$ZINIT_HOME/zinit.zsh" ]]; then
    log "Updating zinit plugins..."
    zsh -ic 'zinit self-update; zinit update --all' || warn "zinit update failed"
fi

# pnpm — self-update, refresh the Node LTS runtime, and update global
# packages (Codex lives here; the self-updating agents are below).
if command -v pnpm &>/dev/null; then
    log "Updating pnpm, Node LTS, and pnpm global packages..."
    pnpm self-update || warn "pnpm self-update failed"
    pnpm runtime set node lts -g || warn "pnpm runtime set node lts failed"
    pnpm update -g || warn "pnpm update -g failed"
    # `pnpm update -g` can re-link @pnpm/exe as an ordinary global dep, reverting
    # its `pnpm` to the 34-byte npm placeholder: the native binary is only ever
    # placed by the SEA self-install (`pnpm setup`), and setup.js — the preinstall
    # that hardlinks it — does not run on a dependency re-link. The shim then execs
    # a text file ("pnpm: 1: This: not found"). Heal via the official installer,
    # the same `pnpm setup --force` path the bootstrap uses.
    if ! pnpm --version >/dev/null 2>&1; then
        warn "pnpm reverted to a placeholder binary after update — reinstalling via get.pnpm.io"
        curl -fsSL https://get.pnpm.io/install.sh | sh - || warn "pnpm reinstall failed"
    fi
fi

# Claude Code — native install (~/.local/bin), self-updates via its own command.
if command -v claude &>/dev/null; then
    log "Updating Claude Code..."
    claude update || warn "Claude Code update failed"
fi

# OpenCode — standalone binary, self-updates via its own command.
if command -v opencode &>/dev/null; then
    log "Upgrading OpenCode..."
    opencode upgrade || warn "OpenCode upgrade failed"
fi

# Antigravity CLI (agy) — standalone binary, self-updates via its own command.
if command -v agy &>/dev/null; then
    log "Updating Antigravity CLI (agy)..."
    agy update || warn "agy update failed"
fi

# Claude Code gstack skill — use the skill's own updater (same as /gstack-upgrade).
if [[ -x "$HOME/.claude/skills/gstack/bin/gstack-update-check" ]]; then
    log "Updating Claude gstack skill..."
    "$HOME/.claude/skills/gstack/bin/gstack-update-check" --force || warn "gstack skill update failed"
fi

if [[ "$WARNINGS" -gt 0 ]]; then
    log "Done with $WARNINGS warning(s) — grep output for 'warning:'."
else
    log "Done."
fi
