#!/usr/bin/env bash
set -euo pipefail

# Install or upgrade Node.js LTS from the official tarball into
# ~/.local/share/node and symlink bins into ~/.local/bin. Idempotent: no-op
# when already on the latest LTS; upgrades in place otherwise. Linux only —
# macOS uses brew node.
#
# Called from scripts/install during bootstrap, and from myshell-update via
# the deployed copy at ~/bin/myshell-install-node-lts.
#
# Gating: if ~/.local/share/node already exists, we own the install and
# always refresh. If it doesn't exist and `node` is provided by the system
# (apt/brew/root), we leave it alone — avoids shadowing a node the operator
# installed deliberately.

dest="$HOME/.local/share/node"
linkdir="$HOME/.local/bin"

sub() { printf '    %s\n' "$*"; }

if [[ "$(uname -s)" != Linux ]]; then
    exit 0
fi

case "$(uname -m)" in
    x86_64)  arch=linux-x64 ;;
    aarch64) arch=linux-arm64 ;;
    *) sub "unsupported arch $(uname -m); skipping node install"; exit 0 ;;
esac

if [[ ! -d "$dest" ]] && command -v node >/dev/null; then
    sub "node already provided by the system ($(command -v node)); skipping tarball install"
    exit 0
fi

# Latest LTS version from the official release index. index.json is one
# record per line sorted newest-first; LTS releases have a quoted codename
# ("lts":"Krypton") while current releases have "lts":false, so the first
# line matching a quoted lts field is the newest LTS. Using .tar.gz (not
# .tar.xz) so minimal containers without xz-utils still work.
index_line=$(curl -fsSL https://nodejs.org/dist/index.json 2>/dev/null \
    | grep -m1 '"lts":"' || true)
latest_ver=""
if [[ $index_line =~ \"version\":\"(v[0-9]+\.[0-9]+\.[0-9]+)\" ]]; then
    latest_ver="${BASH_REMATCH[1]}"
fi
if [[ -z "$latest_ver" ]]; then
    sub "could not determine latest Node LTS version; skipping"
    exit 0
fi
tarball="node-${latest_ver}-${arch}.tar.gz"

current_ver=""
[[ -x "$dest/bin/node" ]] && current_ver=$("$dest/bin/node" --version 2>/dev/null || true)

if [[ "$current_ver" == "$latest_ver" ]]; then
    sub "Node $current_ver already at latest LTS"
    exit 0
fi

if [[ -n "$current_ver" ]]; then
    sub "Upgrading Node $current_ver -> $latest_ver"
else
    sub "Installing Node $latest_ver (official tarball, no apt deps)"
fi

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

if ! curl -fsSL "https://nodejs.org/dist/${latest_ver}/$tarball" | tar -xz -C "$tmp"; then
    sub "tarball download/extract failed; keeping existing install"
    exit 1
fi

mkdir -p "$(dirname "$dest")" "$linkdir"
rm -rf "$dest"
mv "$tmp"/node-*-"$arch" "$dest"

for bin in "$dest/bin/"*; do
    ln -sf "$bin" "$linkdir/$(basename "$bin")"
done

sub "Node $latest_ver installed to $dest"
