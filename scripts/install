#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# myshell stage 2 installer (bash 5)
# =============================================================================
# Invoked by ../bootstrap after brew + bash 5 are ready.
# Idempotent: safe to rerun. Targets macOS (brew) and Ubuntu 22.04+ (apt).
#
# This script is the source of truth. Local rationale lives inline next to the
# code that enforces it; cross-cutting rules that govern many decisions are
# listed here.
#
# Cross-cutting rules:
#
# - Python tooling: `uv` is the only sanctioned Python tool. Never pip, pipx,
#   python -m venv, pyenv, or poetry. Translate upstream `pip install X` or
#   `pipx install X` to `uv tool install X` or a `uv venv` + `uv pip install`.
#   Machines get wedged by pipx + `pip --break-system-packages`; uv is the fix.
#
# - Locale: LANG=zh_TW.UTF-8, LANGUAGE=zh_TW:en. Never bare `zh` (resolves to
#   Simplified on some systems). Never set LC_ALL (it overrides per-category
#   locale control and breaks LANG).
#
# - Timezone: Asia/Taipei.
#
# - gemini-cli: install locally, not `npm install -g`. The global package
#   drags in deprecated prebuild-install. Paths: macOS ~/Library/Application
#   Support/gemini-cli; Ubuntu ~/.local/lib/gemini-cli. `gemini` alias wraps
#   `npx --prefix <path>`.
#
# - tealdeer: the Rust `tealdeer`, not the Python `tldr`. Page language comes
#   from $LANGUAGE (tealdeer has no language option of its own).
#
# - npm: global prefix is ~/.npm-global so globals don't need sudo. PATH
#   pickup is handled in ~/.zshenv.
#
# - zsh layout: ~/.zshenv is sourced by every zsh invocation — PATH, locale,
#   umask, anything non-interactive scripts or cron need. ~/.zsh/*.zsh is
#   interactive-only, sourced from ~/.zshrc.
#
# - Aliases guard on binary presence so a partial install still yields a
#   clean-loading shell.
# =============================================================================

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "$(uname -s)" in
    Darwin) OS=macos ;;
    Linux)  OS=ubuntu ;;
    *) echo "unsupported OS: $(uname -s)" >&2; exit 1 ;;
esac

# Ensure user-local bins (uv, cargo, ~/.local/bin) are reachable in this process.
export PATH="$HOME/bin:$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

log()     { printf '\n==> %s\n' "$*"; }
sublog()  { printf '    %s\n' "$*"; }
die()     { printf 'error: %s\n' "$*" >&2; exit 1; }

# ask PROMPT [DEFAULT] — read a line from tty, echo answer (or default if empty).
ask() {
    local prompt="$1" default="${2:-}" reply
    if [[ -n "$default" ]]; then
        read -rp "$prompt [$default] " reply </dev/tty
    else
        read -rp "$prompt " reply </dev/tty
    fi
    printf '%s\n' "${reply:-$default}"
}

# confirm PROMPT — returns 0 if user answers y/Y, 1 otherwise. Default No.
confirm() {
    local reply
    read -rp "$1 [y/N] " reply </dev/tty
    [[ "$reply" =~ ^[Yy] ]]
}

install_apps() {
    log "Installing core apps..."
    case "$OS" in
        macos)  install_apps_macos ;;
        ubuntu) install_apps_ubuntu ;;
    esac
    install_zinit
}

install_apps_macos() {
    local formulae=(
        git zsh jq tmux fzf ripgrep sevenzip imagemagick ffmpeg uv node
        bat eza fd zoxide starship tealdeer glow qrencode
        watch
    )
    sublog "brew install ${formulae[*]}"
    brew install "${formulae[@]}"
}

install_apps_ubuntu() {
    sublog "apt base packages..."
    sudo apt-get install -y \
        git zsh jq tmux fzf ripgrep 7zip imagemagick ffmpeg curl ca-certificates \
        bat fd-find zoxide tealdeer qrencode build-essential wget gpg \
        nodejs npm locales tzdata

    # Ubuntu names bat/fd differently; symlink into ~/.local/bin so aliases find them.
    mkdir -p "$HOME/.local/bin"
    [[ -x /usr/bin/batcat ]] && ln -sf /usr/bin/batcat "$HOME/.local/bin/bat"
    [[ -x /usr/bin/fdfind ]] && ln -sf /usr/bin/fdfind "$HOME/.local/bin/fd"

    install_uv_ubuntu
    install_starship_ubuntu
    install_eza_ubuntu
    install_glow_ubuntu
}

install_uv_ubuntu() {
    command -v uv >/dev/null && return 0
    sublog "Installing uv (astral.sh installer)..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
}

install_starship_ubuntu() {
    command -v starship >/dev/null && return 0
    sublog "Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- -y
}

install_eza_ubuntu() {
    command -v eza >/dev/null && return 0
    sublog "Installing eza (gierens apt repo)..."
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
        | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
        | sudo tee /etc/apt/sources.list.d/gierens.list >/dev/null
    sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
    sudo apt-get update
    sudo apt-get install -y eza
}

install_glow_ubuntu() {
    command -v glow >/dev/null && return 0
    sublog "Installing glow (charm apt repo)..."
    sudo mkdir -p /etc/apt/keyrings
    curl -fsSL https://repo.charm.sh/apt/gpg.key \
        | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
    echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" \
        | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null
    sudo apt-get update
    sudo apt-get install -y glow
}

install_zinit() {
    local zinit_home="$HOME/.local/share/zinit/zinit.git"
    [[ -d "$zinit_home" ]] && return 0
    sublog "Installing zinit to $zinit_home..."
    mkdir -p "$(dirname "$zinit_home")"
    git clone --depth 1 https://github.com/zdharma-continuum/zinit.git "$zinit_home"
}
deploy_dotfiles() {
    log "Writing zsh dotfiles..."
    mkdir -p "$HOME/.zsh"

    sublog "~/.zshenv"
    cat >"$HOME/.zshenv" <<'EOF'
# Generated by myshell/scripts/install. Sourced by every zsh invocation.

typeset -U path PATH

[[ -d "$HOME/bin" ]]        && path=("$HOME/bin" $path)
[[ -d "$HOME/.local/bin" ]] && path=("$HOME/.local/bin" $path)

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

if (( ${+commands[npm]} )); then
    npm_prefix=$(npm config get prefix 2>/dev/null)
    [[ -n "$npm_prefix" && -d "$npm_prefix/bin" ]] && path=("$npm_prefix/bin" $path)
    unset npm_prefix
fi

[[ -d "$HOME/.cargo/bin" ]] && path=("$HOME/.cargo/bin" $path)

unset LC_ALL
export LANG=zh_TW.UTF-8
export LANGUAGE=zh_TW:en

umask 0077

if [[ "$(uname -s)" == Linux ]]; then
    export XAUTHORITY="$HOME/.Xauthority"
    [[ "$(uname -m)" == aarch64 ]] && export DOCKER_DEFAULT_PLATFORM=linux/arm64
fi
EOF

    sublog "~/.zsh/aliases.zsh"
    cat >"$HOME/.zsh/aliases.zsh" <<'EOF'
# Generated by myshell/scripts/install. Guard each alias on binary presence.

command -v eza      >/dev/null && alias ls='eza --icons'
command -v eza      >/dev/null && alias ll='eza -la --icons --git'
command -v eza      >/dev/null && alias lt='eza --tree --icons'
command -v bat      >/dev/null && alias cat='bat --paging=never'
command -v qrencode >/dev/null && alias qrencode='qrencode -t ansiutf8 -r'
command -v uv       >/dev/null && alias uup='uv tool upgrade --all'
[[ -x "$HOME/bin/update" ]] && alias u="$HOME/bin/update"

# gemini-cli: local npm install, OS-specific location. See script header.
if [[ -d "$HOME/.local/lib/gemini-cli/node_modules/@google/gemini-cli" ]]; then
    alias gemini='npx --prefix "$HOME/.local/lib/gemini-cli" gemini'
elif [[ -d "$HOME/Library/Application Support/gemini-cli/node_modules/@google/gemini-cli" ]]; then
    alias gemini='npx --prefix "$HOME/Library/Application Support/gemini-cli" gemini'
fi
EOF

    sublog "~/.zsh/history.zsh"
    cat >"$HOME/.zsh/history.zsh" <<'EOF'
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000

setopt append_history
setopt share_history
setopt extended_history
setopt hist_expire_dups_first
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_verify

HIST_IGNORE="(ll *|ll|ls *|ls|history|pwd)"

zshaddhistory() {
    local line="${1%%$'\n'}"
    [[ "$line" != ${~HIST_IGNORE} ]]
}
EOF

    sublog "~/.zsh/zoxide.zsh"
    cat >"$HOME/.zsh/zoxide.zsh" <<'EOF'
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
EOF

    if [[ "$OS" == ubuntu ]]; then
        sublog "~/.zsh/motd.zsh"
        cat >"$HOME/.zsh/motd.zsh" <<'EOF'
if [[ -x "/usr/bin/run-parts" ]] && [[ -d "/etc/update-motd.d" ]]; then
    if [[ ! -f "$HOME/.hushlogin" ]]; then
        /usr/bin/run-parts --lsbsysinit /etc/update-motd.d/ 2>/dev/null
    fi
fi
EOF
    else
        # Make sure no stale motd.zsh from a prior Ubuntu install lingers on macOS.
        rm -f "$HOME/.zsh/motd.zsh"
    fi

    sublog "~/.zshrc"
    cat >"$HOME/.zshrc" <<'EOF'
# Generated by myshell/scripts/install.

# zinit
ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
[[ -f "$ZINIT_HOME/zinit.zsh" ]] && source "$ZINIT_HOME/zinit.zsh"

# plugins
zinit snippet OMZL::git.zsh
zinit snippet OMZP::git
zinit snippet OMZP::fzf
zinit light zsh-users/zsh-autosuggestions
zinit light zdharma-continuum/fast-syntax-highlighting
zinit light zsh-users/zsh-completions

# Source custom configs (PATH already set via ~/.zshenv).
for f in ~/.zsh/*.zsh(N); do source "$f"; done

# Ubuntu command-not-found handler
[[ -f /etc/zsh_command_not_found ]] && source /etc/zsh_command_not_found

# Starship prompt (must be last)
command -v starship >/dev/null && eval "$(starship init zsh)"
EOF
}
deploy_scripts() {
    log "Deploying helper scripts and configs..."

    sublog "~/bin/update"
    mkdir -p "$HOME/bin"
    cp "$REPO_ROOT/scripts/update" "$HOME/bin/update"
    chmod +x "$HOME/bin/update"

    sublog "~/.config/starship.toml"
    mkdir -p "$HOME/.config"
    curl -fsSL https://github.com/enstw/myshell-starship/raw/refs/heads/master/starship.toml \
         -o "$HOME/.config/starship.toml"

    sublog "eza tokyonight theme"
    local eza_dir
    if [[ "$OS" == macos ]]; then
        eza_dir="$HOME/Library/Application Support/eza"
    else
        eza_dir="$HOME/.config/eza"
    fi
    mkdir -p "$eza_dir"
    curl -fsSL https://raw.githubusercontent.com/eza-community/eza-themes/main/themes/tokyonight.yml \
         -o "$eza_dir/theme.yml"
}
configure_git() {
    log "Configuring git identity..."
    local current_name current_email new_name new_email
    current_name=$(git config --global user.name  2>/dev/null || true)
    current_email=$(git config --global user.email 2>/dev/null || true)
    new_name=$(ask "git user.name?"  "$current_name")
    new_email=$(ask "git user.email?" "$current_email")
    git config --global user.name  "$new_name"
    git config --global user.email "$new_email"
    sublog "$new_name <$new_email>"
}

configure_locale() {
    if [[ "$OS" != ubuntu ]]; then
        log "Locale generation..."
        sublog "macOS: system locales are available per-user, skipping locale-gen"
        return 0
    fi
    log "Generating locales (en_US, en_GB, zh_TW — .UTF-8)..."
    if ! command -v locale-gen >/dev/null; then
        sublog "locale-gen missing; installing 'locales'..."
        sudo apt-get install -y locales
    fi
    sudo locale-gen en_US.UTF-8 en_GB.UTF-8 zh_TW.UTF-8 >/dev/null
    sudo update-locale LANG=zh_TW.UTF-8 LANGUAGE=zh_TW:en >/dev/null
    sublog "default LANG=zh_TW.UTF-8 LANGUAGE=zh_TW:en"
}

configure_timezone() {
    log "Setting timezone to Asia/Taipei..."
    local target=Asia/Taipei current
    if [[ "$OS" == macos ]]; then
        current=$(sudo systemsetup -gettimezone 2>/dev/null | awk -F': ' '{print $2}' || true)
        if [[ "$current" == "$target" ]]; then
            sublog "already $target"
            return 0
        fi
        sudo systemsetup -settimezone "$target" >/dev/null
    elif command -v timedatectl >/dev/null && timedatectl status >/dev/null 2>&1; then
        current=$(timedatectl show --property=Timezone --value 2>/dev/null || true)
        if [[ "$current" == "$target" ]]; then
            sublog "already $target"
            return 0
        fi
        sudo timedatectl set-timezone "$target"
    else
        # Container / no systemd: write /etc/timezone + relink /etc/localtime.
        echo "$target" | sudo tee /etc/timezone >/dev/null
        sudo ln -sf "/usr/share/zoneinfo/$target" /etc/localtime
    fi
    sublog "set to $target"
}

configure_npm() {
    command -v npm >/dev/null || { log "npm config"; sublog "npm not found, skipping"; return 0; }
    log "Configuring npm global prefix (no-sudo installs)..."
    local prefix_dir="$HOME/.npm-global" current
    mkdir -p "$prefix_dir"
    current=$(npm config get prefix 2>/dev/null || true)
    if [[ "$current" == "$prefix_dir" ]]; then
        sublog "prefix already set to $prefix_dir"
        return 0
    fi
    npm config set prefix "$prefix_dir"
    sublog "prefix set to $prefix_dir (PATH pickup is handled in ~/.zshenv)"
}

install_gemini_cli() {
    command -v npm >/dev/null || { log "gemini-cli"; sublog "npm not found, skipping"; return 0; }
    log "Installing gemini-cli locally..."
    local location
    if [[ "$OS" == macos ]]; then
        location="$HOME/Library/Application Support/gemini-cli"
    else
        location="$HOME/.local/lib/gemini-cli"
    fi
    mkdir -p "$location"
    if [[ ! -f "$location/package.json" ]]; then
        sublog "npm init -y in $location"
        (cd "$location" && npm init -y >/dev/null)
    fi
    if [[ -d "$location/node_modules/@google/gemini-cli" ]]; then
        sublog "already installed at $location"
    else
        sublog "npm install @google/gemini-cli"
        (cd "$location" && npm install @google/gemini-cli)
    fi
    # Remove any legacy global install — its deprecated prebuild-install chain
    # is exactly what this local setup is designed to avoid.
    if npm list -g --depth=0 2>/dev/null | grep -q '@google/gemini-cli'; then
        sublog "removing global @google/gemini-cli"
        npm uninstall -g @google/gemini-cli || true
    fi
}

configure_tealdeer() {
    command -v tldr >/dev/null || { log "tealdeer config"; sublog "tldr not found, skipping"; return 0; }
    log "Configuring tealdeer (auto-update, zh_TW + en pages)..."
    local config_dir
    if [[ "$OS" == macos ]]; then
        config_dir="$HOME/Library/Application Support/tealdeer"
    else
        config_dir="$HOME/.config/tealdeer"
    fi
    mkdir -p "$config_dir"
    # Language preference is controlled by LANGUAGE=zh_TW:en in ~/.zshenv;
    # tealdeer honors it at lookup time.
    cat >"$config_dir/config.toml" <<'EOF'
# Generated by myshell/scripts/install.
# Page language is picked from $LANGUAGE (set to zh_TW:en in ~/.zshenv).

[updates]
auto_update = true
auto_update_interval_hours = 720
EOF
    sublog "fetching page cache (LANGUAGE=zh_TW:en)..."
    if ! LANGUAGE=zh_TW:en tldr --update >/dev/null 2>&1; then
        sublog "tldr --update failed; will retry on first use"
    fi
}

install_fonts() {
    confirm "Install ENS fonts from ent.tw/font?" || return 0
    local fonts_dir tmp urls
    if [[ "$OS" == macos ]]; then
        fonts_dir="$HOME/Library/Fonts"
    else
        fonts_dir="$HOME/.local/share/fonts"
    fi
    mkdir -p "$fonts_dir"
    tmp=$(mktemp -d)
    # No `trap RETURN` for cleanup: RETURN traps persist across subsequent
    # function returns, and the trap body expands "$tmp" at fire time. Once
    # this function's local `tmp` is gone, `set -u` blows up on the next
    # unrelated function return. Inline cleanup is simpler and correct.
    sublog "Fetching release metadata..."
    if curl -fsSL https://ent.tw/font -o "$tmp/release.json"; then
        urls=$(jq -r '.assets[]? | select(.name | endswith(".ttf")) | .browser_download_url' "$tmp/release.json" 2>/dev/null || true)
        if [[ -n "$urls" ]]; then
            while IFS= read -r url; do
                local name="${url##*/}"
                sublog "Downloading $name"
                curl -fsSL "$url" -o "$fonts_dir/$name"
            done <<<"$urls"
            if [[ "$OS" == ubuntu ]] && command -v fc-cache >/dev/null; then
                fc-cache -f >/dev/null
            fi
        else
            sublog "No .ttf assets found; skipping."
        fi
    else
        sublog "Fetch failed; skipping."
    fi
    rm -rf "$tmp"
}

set_login_shell() {
    log "Login shell..."
    local zsh_path
    zsh_path=$(command -v zsh || true)
    [[ -z "$zsh_path" ]] && { sublog "zsh not found, skipping."; return 0; }
    if [[ "${SHELL:-}" == "$zsh_path" ]]; then
        sublog "already zsh"
        return 0
    fi
    if ! grep -qx "$zsh_path" /etc/shells 2>/dev/null; then
        sublog "Adding $zsh_path to /etc/shells (sudo)..."
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi
    if confirm "Set login shell to $zsh_path?"; then
        chsh -s "$zsh_path"
    fi
}

main() {
    log "myshell stage 2 — $OS"
    install_apps
    deploy_dotfiles
    deploy_scripts
    configure_git
    configure_locale
    configure_timezone
    configure_npm
    install_gemini_cli
    configure_tealdeer
    install_fonts
    set_login_shell
    log "Done. Start a new shell to pick up changes."
}

main "$@"
