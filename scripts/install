#!/usr/bin/env bash
set -Eeuo pipefail

# =============================================================================
# myshell stage 2 installer (bash 5)
# =============================================================================
# Invoked by ../bootstrap after brew + bash 5 are ready.
# Idempotent: safe to rerun. Targets macOS (brew) and Ubuntu 22.04+ (apt).
#
# This script is the source of truth. Local rationale lives inline next to the
# code that enforces it; cross-cutting rules that govern many decisions are
# listed here.
#
# Cross-cutting rules:
#
# - Architecture: stage 2 stays ONE file on purpose. curl|sh mode runs
#   bootstrap before any checkout exists and myshell-update is deployed
#   standalone to ~/bin, so sourced libs can't reach all three scripts —
#   splitting into modules would multiply the byte-identical-copy problem,
#   not solve it. Adding a step: write a check-first function (a re-run must
#   be quiet), prompt only via gather_answers + a recorded answer under
#   $STATE_DIR, fail hard only if the shell is broken without it (otherwise
#   warn), add it to main() in dependency order, and cover the result in
#   scripts/ci-roundtrip.
#
# - Python tooling: `uv` is the only sanctioned Python tool. Never pip, pipx,
#   python -m venv, pyenv, or poetry. Translate upstream `pip install X` or
#   `pipx install X` to `uv tool install X` or a `uv venv` + `uv pip install`.
#   Machines get wedged by pipx + `pip --break-system-packages`; uv is the fix.
#   Enforced, not just documented: `purge_non_uv_python` actively removes
#   brew/apt pipx/poetry/pyenv and the per-user dirs their installers drop.
#
# - Locale: LANG=zh_TW.UTF-8, LANGUAGE=zh_TW:en. Never bare `zh` (resolves to
#   Simplified on some systems). Never set LC_ALL (it overrides per-category
#   locale control and breaks LANG).
#
# - Timezone: Asia/Taipei.
#
# - AI agents: optional. ONE menu covers all four — Claude Code, Codex,
#   OpenCode, Antigravity CLI (`agy`, the replacement for the retired Gemini
#   CLI) — and the normalized answer is recorded in
#   ~/.local/state/myshell/agents so re-runs honor it (including "none")
#   instead of re-asking; delete the file to choose again. Codex installs via
#   `pnpm add -g` into $PNPM_HOME (static binary, no self-updater, so
#   `pnpm update -g` is its update path). Claude Code, OpenCode, and agy are
#   standalone self-updating binaries, NOT pnpm-managed (see the bun note):
#   their own updaters would fight a package manager, and $PNPM_HOME precedes
#   ~/.local/bin in PATH so a stale pnpm copy would shadow them. claude and
#   agy land in ~/.local/bin (already on PATH); opencode in ~/.opencode/bin.
#
# - tealdeer: the Rust `tealdeer`, not the Python `tldr`. Page language comes
#   from $LANGUAGE (tealdeer has no language option of its own).
#
# - Node/pnpm: this machine is pnpm-only. pnpm is installed standalone (the
#   self-contained @pnpm/exe build via get.pnpm.io) on both macOS and Ubuntu,
#   and pnpm itself provisions the Node runtime (`pnpm runtime set node lts -g`).
#   There is no separate `node`/`npm` install: npm/npx ship inside pnpm's Node
#   but are not used. Global bins live in $PNPM_HOME; PATH pickup is in ~/.zshenv.
#   Enforced, not just documented: `purge_non_pnpm_node` actively removes
#   brew/apt node/npm/yarn and version managers (nvm/fnm/volta/asdf-node),
#   sweeps stale myshell-managed agent packages and orphaned npm/corepack from
#   npm-global prefixes, and warns on any other lingering npm-globals.
#
# - bun: installed via its own bun.sh installer into ~/.bun — a peer runtime
#   required by the gstack skill, NOT part of the pnpm-only policy. It doesn't
#   go through npm, so leave it alone; it isn't a stray npm-ish tool to purge.
#
# - Interactive answers: every prompt runs up front in gather_answers, and
#   each answer is recorded under ~/.local/state/myshell/ — the user's
#   decision, not system state, is the idempotency key, so re-runs are quiet
#   and the long package phase runs unattended (chsh may still ask for a
#   password at the very end). Delete a state file to be asked again.
#   Headless runs: pre-seed the state files and git identity beforehand.
#
# - Failure policy: required tools abort the run via the ERR trap (brew/apt
#   base packages, uv, starship, zinit, the eza/glow apt repos) — a shell
#   without them is broken anyway. Optional or self-healing steps fail soft
#   (pnpm, bun, AI agents, fetched configs, tealdeer cache, fonts): a
#   transient network blip must not kill a bootstrap halfway (2026-05-10).
#
# - Output vocabulary: log (step header), sublog (detail), warn (fail-soft
#   failures and work deferred to the operator — counted and reported in the
#   final Done line), die (fatal). log/sublog go to stdout; warn/die/ERR trap
#   to stderr, so an unattended run is audited with `grep '^warning:'`.
#   Definitions are POSIX-sh-safe and deliberately duplicated byte-identical
#   across bootstrap, scripts/install, and scripts/myshell-update (one runs
#   pre-checkout, one is deployed standalone — no sourced lib can reach all
#   three); drift between the copies is a bug. Grammar: in-progress lines end
#   in "...", results/skips read "<thing> — skipping" with no trailing period.
#
# - zsh layout: ~/.zshenv is sourced by every zsh invocation — PATH, locale,
#   umask, anything non-interactive scripts or cron need. ~/.zsh/*.zsh is
#   interactive-only, sourced from ~/.zshrc.
#
# - Aliases guard on binary presence so a partial install still yields a
#   clean-loading shell.
# =============================================================================

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "$(uname -s)" in
    Darwin) OS=macos ;;
    Linux)  OS=ubuntu ;;
    *) echo "unsupported OS: $(uname -s)" >&2; exit 1 ;;
esac

# pnpm home: unified across macOS and Ubuntu so install-time `pnpm add -g` and
# `pnpm runtime` target a known dir, and global bins are reachable for the rest of
# this run. The generated ~/.zshenv exports the same value for login shells.
export PNPM_HOME="$HOME/.local/share/pnpm"
mkdir -p "$PNPM_HOME"

# Ensure user-local bins (uv, cargo, ~/.local/bin, pnpm) are reachable in this
# process. pnpm 11 shims live in $PNPM_HOME/bin; old layout used $PNPM_HOME.
export PATH="$PNPM_HOME/bin:$PNPM_HOME:$HOME/bin:$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# Recorded interactive answers live here (see the header rule): one file per
# question, written by the choose_* helpers, honored on every re-run.
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/myshell"

# Output vocabulary (see the header rule) — deliberately duplicated
# byte-identical in ../bootstrap and ./myshell-update; drift is a bug.
WARNINGS=0
log()    { printf '\n==> %s\n' "$*"; }
sublog() { printf '    %s\n' "$*"; }
warn()   { printf 'warning: %s\n' "$*" >&2; WARNINGS=$((WARNINGS+1)); }
die()    { printf 'error: %s\n' "$*" >&2; exit 1; }
trap 'rc=$?; printf "error: failed at line %s: %s (exit %s)\n" "$LINENO" "$BASH_COMMAND" "$rc" >&2; exit "$rc"' ERR

# sudo shim:
#   - root            -> no prefix needed.
#   - non-root+sudo   -> prefix system commands with sudo.
#   - non-root+nosudo -> NO_SUDO=1; system-level steps (apt installs,
#     locale-gen, timezone, /etc/shells) are skipped and the bootstrap is
#     reduced to user-level config. The operator is expected to have
#     pre-installed required system packages via the root account.
# NO_SUDO is inherited from stage 1 when invoked via bootstrap; re-detected
# here so stage 2 can also be run standalone.
if [[ $EUID -eq 0 ]]; then
    SUDO=""
    NO_SUDO=0
elif command -v sudo >/dev/null 2>&1; then
    SUDO=sudo
    NO_SUDO=0
else
    log "No sudo and not root — running no-sudo bootstrap (skipping system-level steps)"
    SUDO=""
    NO_SUDO=1
fi

# ask PROMPT [DEFAULT] — read a line from tty, echo answer (or default if empty).
ask() {
    local prompt="$1" default="${2:-}" reply
    if [[ -n "$default" ]]; then
        read -rp "$prompt [$default] " reply </dev/tty
    else
        read -rp "$prompt " reply </dev/tty
    fi
    printf '%s\n' "${reply:-$default}"
}

# confirm PROMPT — returns 0 if user answers y/Y, 1 otherwise. Default No.
confirm() {
    local reply
    read -rp "$1 [y/N] " reply </dev/tty
    [[ "$reply" =~ ^[Yy] ]]
}

# True when a system-level (sudo) step will actually run this round, so a quiet
# re-run with nothing to do never prompts for a password. Mirrors the guards in
# configure_timezone / set_login_shell so the prediction can't drift into a
# surprise mid-run prompt: apt always needs root; on macOS only a timezone
# change or a missing /etc/shells entry do (brew installs need no sudo).
sudo_work_pending() {
    [[ -n "$SUDO" ]] || return 1
    [[ "$OS" == ubuntu ]] && return 0
    local tz zsh_path
    tz=$(readlink /etc/localtime 2>/dev/null || true)
    [[ "${tz#*/zoneinfo/}" != Asia/Taipei ]] && return 0
    zsh_path=$(command -v zsh || true)
    [[ -n "$zsh_path" ]] && ! grep -qx "$zsh_path" /etc/shells 2>/dev/null && return 0
    return 1
}

# Pre-warm sudo and keep its timestamp fresh for the whole run, so the
# password prompt happens up front (with the other questions) instead of at
# a random later sudo step after a long brew/apt phase. Skipped entirely when
# no sudo-level work is pending, so an already-configured re-run never prompts.
# The keepalive loop watches the script's PID and exits within a minute of the end.
warm_sudo() {
    [[ -n "$SUDO" ]] || return 0
    if ! sudo_work_pending; then
        sublog "no system-level changes pending — skipping sudo pre-auth"
        return 0
    fi
    $SUDO -v
    ( while kill -0 "$$" 2>/dev/null; do $SUDO -n -v 2>/dev/null || true; sleep 60; done ) &
}

# --- gather_answers: every interactive question, asked once, up front -------
# Each choose_* helper is also called at its point of use, so a standalone
# step still prompts — but on a normal run the answer already exists by then.

GIT_NAME=""
GIT_EMAIL=""
gather_git_identity() {
    # git config is its own record for this one — no state file needed. On a
    # bare box git may not exist yet, so stash the answers in globals and let
    # configure_git apply them after install_apps has provided git.
    local current_name current_email
    current_name=$(git config --global user.name  2>/dev/null || true)
    current_email=$(git config --global user.email 2>/dev/null || true)
    [[ -n "$current_name" && -n "$current_email" ]] && return 0
    GIT_NAME=$(ask "git user.name?"  "$current_name")
    GIT_EMAIL=$(ask "git user.email?" "$current_email")
}

choose_agents() {
    [[ -f "$STATE_DIR/agents" ]] && return 0
    sublog "AI agents — pick numbers, comma-separated: 0 none, 1 Claude Code, 2 Codex, 3 OpenCode, 4 agy, 5 all."
    sublog "Names work too: all, none, or e.g. claude,opencode."
    local selected
    selected=$(normalize_agent_choice "$(ask "Install which agents?" "1,2")")
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$selected" >"$STATE_DIR/agents"
    sublog "choice recorded (${selected:-none}) — rm $STATE_DIR/agents to change it"
}

choose_fonts() {
    [[ -f "$STATE_DIR/fonts" ]] && return 0
    # Font already on disk: skip WITHOUT recording — the user never answered,
    # and the state files record decisions, not inferred state. If the font
    # is later deleted deliberately, the next run asks again instead of
    # silently re-installing on a fabricated "yes".
    [[ -f "$(ens_fonts_dir)/ENSFont.ttc" ]] && return 0
    local answer=no
    if confirm "Install ENS fonts from github.com/enstw/font?"; then
        answer=yes
    fi
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$answer" >"$STATE_DIR/fonts"
}

choose_login_shell() {
    [[ -f "$STATE_DIR/login-shell" ]] && return 0
    # Already on zsh: skip WITHOUT recording — the user never answered (same
    # rationale as choose_fonts). If they later switch away deliberately,
    # the next run asks instead of silently chsh-ing them back.
    local current answer=no
    current=$(current_login_shell)
    [[ "${current##*/}" == zsh ]] && return 0
    if confirm "Set login shell to zsh?"; then
        answer=yes
    fi
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$answer" >"$STATE_DIR/login-shell"
}

gather_answers() {
    log "Questions first — the rest of the run is unattended (re-runs skip answered ones)"
    warm_sudo
    gather_git_identity
    choose_agents
    choose_fonts
    choose_login_shell
}

install_apps() {
    log "Installing core apps..."
    case "$OS" in
        macos)  install_apps_macos ;;
        ubuntu) install_apps_ubuntu ;;
    esac
    install_pnpm
    install_bun
    install_zinit
}

install_pnpm() {
    # Standalone pnpm (the self-contained @pnpm/exe build) on both OSes — same
    # curl|sh pattern as bun/uv/starship/Homebrew. This build bundles its own
    # Node and later provisions a runtime via `pnpm runtime set node lts -g`.
    #
    # NOT the Homebrew formula: brew's `pnpm` is the plain JS build that needs a
    # separate `node` to run ("pnpm requires a Node installation to function").
    # With no node, it's broken. Remove it so it can't shadow the standalone one.
    if [[ "$OS" == macos ]] && brew list --formula pnpm >/dev/null 2>&1; then
        sublog "Removing Homebrew pnpm (needs external node) in favor of the standalone build..."
        brew uninstall pnpm >/dev/null 2>&1 || true
    fi

    # Idempotency keys on the standalone binary in $PNPM_HOME, not just any pnpm
    # on PATH — so a leftover brew pnpm never causes us to skip the install. pnpm
    # 11 installs the shim at $PNPM_HOME/bin/pnpm; older layouts used
    # $PNPM_HOME/pnpm. Accept either so re-runs don't reinstall on every pass.
    if [[ -x "$PNPM_HOME/bin/pnpm" || -x "$PNPM_HOME/pnpm" ]]; then
        sublog "pnpm already installed — skipping"
        return 0
    fi
    sublog "Installing pnpm (get.pnpm.io standalone installer)..."
    # PNPM_HOME is already exported (see top of script); the installer honors it
    # so the home is identical on macOS and Ubuntu. It also appends a PNPM_HOME
    # block to ~/.zshrc/~/.bashrc — harmless; our generated ~/.zshenv owns PATH.
    if ! curl -fsSL https://get.pnpm.io/install.sh | sh -; then
        warn "pnpm install failed; continuing (node/Codex steps will skip)"
        return 0
    fi
    [[ -x "$PNPM_HOME/bin/pnpm" || -x "$PNPM_HOME/pnpm" ]] \
        && sublog "pnpm installed" \
        || warn "pnpm installer finished but no pnpm binary found; continuing"
}

install_apps_macos() {
    local formulae=(
        git zsh jq tmux fzf ripgrep sevenzip uv
        ca-certificates
        bat eza fd zoxide starship tealdeer glow qrencode
        watch
    )
    # Check-first: brew install skips installed formulae anyway, but invoking it
    # at all pays tap/update overhead on every re-run — only call it for what's
    # actually missing.
    local installed missing=() f
    installed=$(brew list --formula)
    for f in "${formulae[@]}"; do
        grep -qx "$f" <<<"$installed" || missing+=("$f")
    done
    if [[ ${#missing[@]} -eq 0 ]]; then
        sublog "all brew formulae already installed — skipping"
    else
        sublog "brew install ${missing[*]}"
        brew install "${missing[@]}"
    fi
    # Refresh the CA bundle on a fresh Mac so later curl|sh installers (pnpm,
    # bun) and pnpm's registry TLS have a trusted root store.
    brew postinstall ca-certificates >/dev/null 2>&1 || true
}

install_apps_ubuntu() {
    if [[ "$NO_SUDO" == "1" ]]; then
        warn "no sudo — skipping apt installs; system packages assumed pre-installed via root"
    else
        # Check-first: apt-get install -y is idempotent but slow when invoked
        # for already-present packages — only ask it for what dpkg lacks.
        # unzip is required by the bun.sh installer (it errors "unzip is
        # required to install bun" otherwise); without it install_bun fails
        # soft on minimal Ubuntu and the gstack skill loses its bun runtime.
        local pkgs=(
            git zsh jq tmux fzf ripgrep 7zip curl ca-certificates
            bat fd-find zoxide tealdeer qrencode build-essential wget gpg
            unzip locales tzdata
        )
        local missing=() p
        for p in "${pkgs[@]}"; do
            dpkg -s "$p" >/dev/null 2>&1 || missing+=("$p")
        done
        if [[ ${#missing[@]} -eq 0 ]]; then
            sublog "apt base packages already installed — skipping"
        else
            # Standalone stage-2 runs (without bootstrap) may sit on a stale
            # or empty index; bootstrap exports MYSHELL_APT_UPDATED after its
            # own apt-get update so the normal path doesn't update twice.
            if [[ "${MYSHELL_APT_UPDATED:-0}" != 1 ]]; then
                sublog "apt-get update (no fresh index from stage 1)"
                $SUDO apt-get update
            fi
            sublog "apt install ${missing[*]}"
            $SUDO apt-get install -y "${missing[@]}"
        fi
    fi

    # Ubuntu names bat/fd differently; symlink into ~/.local/bin so aliases find them.
    mkdir -p "$HOME/.local/bin"
    [[ -x /usr/bin/batcat ]] && ln -sf /usr/bin/batcat "$HOME/.local/bin/bat"
    [[ -x /usr/bin/fdfind ]] && ln -sf /usr/bin/fdfind "$HOME/.local/bin/fd"

    install_uv_ubuntu
    install_starship_ubuntu
    if [[ "$NO_SUDO" == "1" ]]; then
        warn "no sudo — skipping eza/glow (require apt-repo setup under /etc)"
    else
        install_eza_ubuntu
        install_glow_ubuntu
    fi
}

unminimize_ubuntu() {
    # Minimized Ubuntu images (cloud/docker bases) strip man pages and docs
    # via dpkg path-excludes. This machine is for interactive use, so restore
    # them. The excludes file is the minimized marker and unminimize removes
    # it when done — which makes this check-first on re-runs.
    [[ "$OS" == ubuntu ]] || return 0
    log "Unminimizing Ubuntu (restore man pages/docs for interactive use)..."
    if [[ ! -f /etc/dpkg/dpkg.cfg.d/excludes ]]; then
        sublog "not minimized (or already unminimized) — skipping"
        return 0
    fi
    if [[ "$NO_SUDO" == "1" ]]; then
        warn "no sudo — skipping unminimize; ask root to run it"
        return 0
    fi
    # The script moved into its own package on Ubuntu 23.04+; older images
    # ship it at /usr/local/sbin, which may not be on a user PATH.
    local unmin
    if command -v unminimize >/dev/null; then
        unmin=$(command -v unminimize)
    elif [[ -x /usr/local/sbin/unminimize ]]; then
        unmin=/usr/local/sbin/unminimize
    else
        sublog "installing unminimize..."
        if ! $SUDO apt-get install -y unminimize; then
            warn "could not install unminimize — skipping"
            return 0
        fi
        unmin=$(command -v unminimize || echo /usr/bin/unminimize)
    fi
    sublog "running unminimize (reinstalls docs — takes a few minutes)..."
    # `yes |` feeds its confirmation prompts; yes then dies of SIGPIPE when
    # unminimize exits, which pipefail would misread as a failure — disable
    # pipefail around the pipeline so the status is unminimize's own.
    set +o pipefail
    yes | $SUDO "$unmin" || warn "unminimize failed — re-run to retry"
    set -o pipefail
}

install_uv_ubuntu() {
    command -v uv >/dev/null && return 0
    sublog "Installing uv (astral.sh installer)..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
}

install_starship_ubuntu() {
    command -v starship >/dev/null && return 0
    sublog "Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- -y
}

install_eza_ubuntu() {
    command -v eza >/dev/null && return 0
    sublog "Installing eza (gierens apt repo)..."
    $SUDO mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc \
        | $SUDO gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" \
        | $SUDO tee /etc/apt/sources.list.d/gierens.list >/dev/null
    $SUDO chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
    $SUDO apt-get update
    $SUDO apt-get install -y eza
}

install_glow_ubuntu() {
    command -v glow >/dev/null && return 0
    sublog "Installing glow (charm apt repo)..."
    $SUDO mkdir -p /etc/apt/keyrings
    curl -fsSL https://repo.charm.sh/apt/gpg.key \
        | $SUDO gpg --dearmor -o /etc/apt/keyrings/charm.gpg
    echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" \
        | $SUDO tee /etc/apt/sources.list.d/charm.list >/dev/null
    $SUDO apt-get update
    $SUDO apt-get install -y glow
}

install_bun() {
    # bun isn't in default Homebrew (requires the oven-sh/bun tap) and isn't
    # in apt, so use the upstream installer on both OSes. Drops binary +
    # completions into ~/.bun. PATH is picked up via ~/.zshenv; completions
    # are sourced from ~/.zsh/bun.zsh. Needed by the gstack skill's setup.
    command -v bun >/dev/null && return 0
    sublog "Installing bun (bun.sh installer)..."
    if ! curl -fsSL https://bun.sh/install | bash; then
        warn "bun install failed; continuing without bun"
        return 0
    fi
    if [[ -x "$HOME/.bun/bin/bun" ]]; then
        sublog "bun installed to $HOME/.bun/bin/bun"
    elif command -v bun >/dev/null; then
        sublog "bun installed ($(command -v bun))"
    else
        warn "bun installer exited successfully, but bun was not found; continuing"
    fi
}

install_zinit() {
    local zinit_home="$HOME/.local/share/zinit/zinit.git"
    [[ -d "$zinit_home" ]] && return 0
    sublog "Installing zinit to $zinit_home..."
    mkdir -p "$(dirname "$zinit_home")"
    git clone --depth 1 https://github.com/zdharma-continuum/zinit.git "$zinit_home"
}

# Policy enforcement: actively remove tools that compete with uv (Python) or
# pnpm (Node). The header rules already say "never pip/pipx/poetry/pyenv" and
# "pnpm-only", so a stray version manager or apt-node is a bug, not a choice —
# leaving them around lets PATH order silently pick the wrong binary. Both
# functions are fail-soft and check-first: a clean machine prints "nothing to
# purge" and moves on; a brew/apt dependency conflict warns instead of aborting.
purge_conflicts() {
    log "Purging non-sanctioned Python/Node tools..."
    purge_non_uv_python
    purge_non_pnpm_node
}

purge_non_uv_python() {
    # System python3 (apt/brew) is left alone — OS tools depend on it. Targets
    # are user-managed shells around it: pipx, poetry, pyenv (brew/apt and the
    # per-user dirs their installers drop).
    local removed=() f p d
    if [[ "$OS" == macos ]]; then
        for f in pipx poetry pyenv; do
            brew list --formula "$f" >/dev/null 2>&1 || continue
            if brew uninstall "$f" >/dev/null 2>&1; then
                removed+=("brew:$f")
            else
                warn "brew uninstall $f failed (dependents?)"
            fi
        done
    elif [[ "$NO_SUDO" != 1 ]]; then
        for p in pipx python3-poetry pyenv; do
            dpkg -s "$p" >/dev/null 2>&1 || continue
            if $SUDO apt-get purge -y "$p" >/dev/null 2>&1; then
                removed+=("apt:$p")
            else
                warn "apt purge $p failed"
            fi
        done
    fi
    for d in "$HOME/.pyenv" "$HOME/.local/pipx" \
             "$HOME/.local/share/pypoetry" "$HOME/.cache/pypoetry"; do
        [[ -e "$d" ]] || continue
        if rm -rf "$d"; then
            removed+=("${d/#$HOME/~}")
        else
            warn "rm $d failed"
        fi
    done
    # poetry's official installer drops a shim here that survives the dirs above.
    if [[ -e "$HOME/.local/bin/poetry" ]]; then
        rm -f "$HOME/.local/bin/poetry" \
            && removed+=("~/.local/bin/poetry") \
            || warn "rm ~/.local/bin/poetry failed"
    fi
    if [[ ${#removed[@]} -eq 0 ]]; then
        sublog "Python: nothing to purge (uv-only)"
    else
        sublog "Python: removed ${removed[*]}"
    fi
}

purge_non_pnpm_node() {
    # pnpm provisions its own Node and $PNPM_HOME/bin precedes other dirs in
    # PATH — but a brew/apt `node` still wins for non-shell consumers (cron,
    # systemd, GUI launchers), and `nvm`/`fnm` shells override PATH from
    # ~/.zshrc anyway. Strip them all so the pnpm runtime is the only Node.
    local removed=() f p d
    if [[ "$OS" == macos ]]; then
        # Sweep the versioned node@X family too — past `brew install node@20`
        # etc. are common leftovers. The standalone pnpm install_pnpm already
        # handles brew pnpm, so it isn't repeated here.
        for f in node node@lts node@20 node@22 node@24 npm yarn fnm volta; do
            brew list --formula "$f" >/dev/null 2>&1 || continue
            if brew uninstall "$f" >/dev/null 2>&1; then
                removed+=("brew:$f")
            else
                warn "brew uninstall $f failed (dependents?)"
            fi
        done
    elif [[ "$NO_SUDO" != 1 ]]; then
        for p in nodejs npm yarn yarnpkg fnm; do
            dpkg -s "$p" >/dev/null 2>&1 || continue
            if $SUDO apt-get purge -y "$p" >/dev/null 2>&1; then
                removed+=("apt:$p")
            else
                warn "apt purge $p failed"
            fi
        done
    fi
    for d in "$HOME/.nvm" "$HOME/.fnm" "$HOME/.volta"; do
        [[ -e "$d" ]] || continue
        if rm -rf "$d"; then
            removed+=("${d/#$HOME/~}")
        else
            warn "rm $d failed"
        fi
    done
    # asdf node plugin only — the rest of asdf may host other languages the
    # user wants. Remove the plugin definition, installed versions, and shim.
    if [[ -d "$HOME/.asdf/plugins/nodejs" ]]; then
        if rm -rf "$HOME/.asdf/plugins/nodejs" \
                  "$HOME/.asdf/installs/nodejs" \
                  "$HOME/.asdf/shims/node" 2>/dev/null; then
            removed+=("asdf:nodejs")
        else
            warn "rm asdf nodejs plugin failed"
        fi
    fi
    # npm globals outside pnpm's prefix fall into three buckets:
    #   1. Agent packages myshell used to drop under an npm global prefix but
    #      now manages elsewhere — Claude Code and agy are native, Codex is
    #      pnpm, and the Gemini CLI is retired (agy replaced it). Ours to remove
    #      wherever they linger; their bin shims go when ~/.npm-global is nuked.
    #   2. The node toolchain itself (npm/npx/corepack) orphaned in a brew root
    #      with no `node` formula owning it — pure cruft under pnpm-only.
    #   3. Anything else — possibly load-bearing CLIs the user installed years
    #      ago. Warn, never delete.
    local g root pkg
    local stale_pkgs=(@anthropic-ai/claude-code @openai/codex @google/gemini-cli)
    local brew_node_gone=0
    [[ "$OS" == macos ]] && ! brew list --formula node >/dev/null 2>&1 && brew_node_gone=1
    for root in /usr/local /opt/homebrew "$HOME/.npm-global"; do
        [[ -d "$root/lib/node_modules" ]] || continue
        for pkg in "${stale_pkgs[@]}"; do
            [[ -e "$root/lib/node_modules/$pkg" ]] || continue
            rm -rf "$root/lib/node_modules/$pkg" \
                && removed+=("npm:$pkg") \
                || warn "rm $root/lib/node_modules/$pkg failed"
        done
        # Orphaned toolchain only in brew roots, and only when no brew node owns it.
        if [[ "$brew_node_gone" == 1 && "$root" != "$HOME/.npm-global" ]]; then
            for pkg in npm npx corepack; do
                [[ -e "$root/lib/node_modules/$pkg" ]] || continue
                rm -rf "$root/lib/node_modules/$pkg" \
                    && removed+=("npm:$pkg ($root)") \
                    || warn "rm $root/lib/node_modules/$pkg failed"
            done
        fi
    done
    # The legacy ~/.npm-global is entirely ours/cruft: if nothing real remains
    # under it, remove the whole tree (its bin/ holds only dangling shims now).
    # Prune empty @scope dirs left by the removals (and pre-existing orphans like
    # an emptied @google) first, so the leftovers check sees only real packages.
    if [[ -d "$HOME/.npm-global" ]]; then
        find "$HOME/.npm-global/lib/node_modules" -mindepth 1 -type d -empty -delete 2>/dev/null || true
        if find "$HOME/.npm-global/lib/node_modules" -mindepth 1 -maxdepth 1 \
             -not -name '.*' 2>/dev/null | grep -q .; then
            warn "npm globals linger in ~/.npm-global — review and remove if unused"
        else
            rm -rf "$HOME/.npm-global" && removed+=("~/.npm-global")
        fi
    fi
    # Brew/usr roots are shared with Homebrew: warn on genuine leftovers, never
    # delete (a stray link there could be load-bearing).
    for g in /usr/local/lib/node_modules /opt/homebrew/lib/node_modules; do
        [[ -d "$g" ]] || continue
        if find "$g" -mindepth 1 -maxdepth 1 -not -name '.*' 2>/dev/null \
             | grep -q .; then
            warn "npm globals linger in $g — review and remove if unused"
        fi
    done
    if [[ ${#removed[@]} -eq 0 ]]; then
        sublog "Node: nothing to purge (pnpm-only)"
    else
        sublog "Node: removed ${removed[*]}"
    fi
}
deploy_dotfiles() {
    log "Writing zsh dotfiles..."
    mkdir -p "$HOME/.zsh"

    sublog "~/.zshenv"
    cat >"$HOME/.zshenv" <<'EOF'
# Generated by myshell/scripts/install — do not hand-edit (rewritten on
# every bootstrap run). Sourced by every zsh invocation.

typeset -U path PATH

[[ -d "$HOME/bin" ]]        && path=("$HOME/bin" $path)
[[ -d "$HOME/.local/bin" ]] && path=("$HOME/.local/bin" $path)

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# `brew shellenv` prepends its completions dir to fpath AND marks FPATH exported
# (`export FPATH;`). An exported FPATH is inherited by child shells and frozen
# there — including the version-pinned core functions dir from zsh's compiled-in
# default (…/Cellar/zsh/<ver>/share/zsh/functions). Once `brew upgrade zsh` bumps
# that version the baked path is gone, so every shell descended from a pre-upgrade
# session can no longer load _main_complete & co. ("function definition file not
# found" — completion + autosuggestions break). Three guards:
#   1. re-add brew's stable, non-versioned functions dir so the core completion
#      functions stay reachable even if an inherited fpath lost its Cellar entry;
#   2. de-dupe (FPATH otherwise accumulates a copy per nested shell);
#   3. un-export so each zsh re-derives fpath from its own current binary and the
#      value never freezes (zshenv runs for every zsh, so children self-heal).
[[ -n "$HOMEBREW_PREFIX" && -d "$HOMEBREW_PREFIX/share/zsh/functions" ]] \
    && fpath=("$HOMEBREW_PREFIX/share/zsh/functions" $fpath)
typeset -U fpath
typeset +x FPATH

# pnpm: global bins + the node runtime pnpm provisions live here. pnpm 11 puts
# shims in $PNPM_HOME/bin; older layouts used $PNPM_HOME directly. Add both.
export PNPM_HOME="$HOME/.local/share/pnpm"
[[ -d "$PNPM_HOME/bin" ]] && path=("$PNPM_HOME/bin" $path)
[[ -d "$PNPM_HOME" ]]     && path=("$PNPM_HOME" $path)

[[ -d "$HOME/.cargo/bin" ]]    && path=("$HOME/.cargo/bin" $path)
[[ -d "$HOME/.bun/bin" ]]      && path=("$HOME/.bun/bin" $path)
[[ -d "$HOME/.opencode/bin" ]] && path=("$HOME/.opencode/bin" $path)

unset LC_ALL
export LANG=zh_TW.UTF-8
export LANGUAGE=zh_TW:en
export COLORTERM=truecolor

umask 0077

if [[ "$(uname -s)" == Linux ]]; then
    export XAUTHORITY="$HOME/.Xauthority"
    [[ "$(uname -m)" == aarch64 ]] && export DOCKER_DEFAULT_PLATFORM=linux/arm64
fi
EOF

    sublog "~/.zsh/aliases.zsh"
    cat >"$HOME/.zsh/aliases.zsh" <<'EOF'
# Generated by myshell/scripts/install — do not hand-edit (rewritten on
# every bootstrap run). Guard each alias on binary presence.

command -v eza      >/dev/null && alias ls='eza --icons'
command -v eza      >/dev/null && alias ll='eza -la --icons --git'
command -v eza      >/dev/null && alias lt='eza --tree --icons'
command -v bat      >/dev/null && alias cat='bat --paging=never'
command -v qrencode >/dev/null && alias qrencode='qrencode -t ansiutf8 -r'
command -v uv       >/dev/null && alias uvu='uv tool upgrade --all'
[[ -x "$HOME/bin/myshell-update" ]] && alias u="$HOME/bin/myshell-update"

# This machine is pnpm-only. `npx` maps to `pnpm dlx`; `npm` is guarded with a
# function (not a flat alias — subcommands differ, e.g. `npm i -g X` is
# `pnpm add -g X`) so a stray `npm` nudges to pnpm instead of running wrong.
command -v pnpm >/dev/null && alias npx='pnpm dlx'
command -v pnpm >/dev/null && npm() {
    print -u2 "npm is disabled on this machine — use pnpm (npx -> 'pnpm dlx', npm i -g X -> 'pnpm add -g X')."
    print -u2 "Ran: npm $*"
    return 127
}

EOF

    sublog "~/.zsh/history.zsh"
    cat >"$HOME/.zsh/history.zsh" <<'EOF'
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000

setopt append_history
setopt share_history
setopt extended_history
setopt hist_expire_dups_first
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_verify

HIST_IGNORE="(ll *|ll|ls *|ls|history|pwd)"

zshaddhistory() {
    local line="${1%%$'\n'}"
    [[ "$line" != ${~HIST_IGNORE} ]]
}
EOF

    sublog "~/.zsh/zoxide.zsh"
    cat >"$HOME/.zsh/zoxide.zsh" <<'EOF'
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
EOF

    sublog "~/.zsh/bun.zsh"
    cat >"$HOME/.zsh/bun.zsh" <<'EOF'
# bun completions (PATH is set in ~/.zshenv).
[[ -s "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"
EOF

    if [[ "$OS" == ubuntu ]]; then
        sublog "~/.zsh/motd.zsh"
        cat >"$HOME/.zsh/motd.zsh" <<'EOF'
if [[ -x "/usr/bin/run-parts" ]] && [[ -d "/etc/update-motd.d" ]]; then
    if [[ ! -f "$HOME/.hushlogin" ]]; then
        /usr/bin/run-parts --lsbsysinit /etc/update-motd.d/ 2>/dev/null
    fi
fi
EOF
    else
        # Make sure no stale motd.zsh from a prior Ubuntu install lingers on macOS.
        rm -f "$HOME/.zsh/motd.zsh"
    fi

    sublog "~/.zshrc"
    cat >"$HOME/.zshrc" <<'EOF'
# Generated by myshell/scripts/install — do not hand-edit (rewritten on
# every bootstrap run). Personal config goes in your own ~/.zsh/<name>.zsh:
# everything in that directory is sourced below, and the installer only
# ever rewrites its own files there.

# zinit
ZINIT_HOME="$HOME/.local/share/zinit/zinit.git"
[[ -f "$ZINIT_HOME/zinit.zsh" ]] && source "$ZINIT_HOME/zinit.zsh"

# plugins
zinit snippet OMZL::git.zsh
zinit snippet OMZP::git
zinit snippet OMZP::fzf
zinit light zsh-users/zsh-autosuggestions
zinit light zdharma-continuum/fast-syntax-highlighting
zinit light zsh-users/zsh-completions

# Source custom configs (PATH already set via ~/.zshenv).
for f in ~/.zsh/*.zsh(N); do source "$f"; done

# Ubuntu command-not-found handler
[[ -f /etc/zsh_command_not_found ]] && source /etc/zsh_command_not_found

# Starship prompt (must be last)
command -v starship >/dev/null && eval "$(starship init zsh)"
EOF
}
# fetch_config URL DEST — refresh DEST from URL on every run (sync semantics),
# but never let a network failure abort the bootstrap: under set -e + the ERR
# trap, a bare `curl -o` here would kill an offline re-run halfway through.
# Downloads to a temp file so a failed transfer can't truncate an existing copy.
fetch_config() {
    local url="$1" dest="$2" tmp
    tmp=$(mktemp)
    if curl -fsSL -o "$tmp" "$url"; then
        mv "$tmp" "$dest"
    else
        rm -f "$tmp"
        if [[ -f "$dest" ]]; then
            warn "download failed; keeping existing $dest"
        else
            warn "download failed; $dest not installed (re-run to retry)"
        fi
    fi
}

deploy_scripts() {
    log "Deploying helper scripts and configs..."

    sublog "~/bin/myshell-update"
    mkdir -p "$HOME/bin"
    # Namespaced name (not ~/bin/update) so we don't clobber whatever
    # personal `update` script the user might already have in ~/bin.
    # The `u` alias in ~/.zsh/aliases.zsh is the user-facing interface.
    cp "$REPO_ROOT/scripts/myshell-update" "$HOME/bin/myshell-update"
    chmod +x "$HOME/bin/myshell-update"

    # Drop the old node-tarball helper from pre-pnpm installs — pnpm now owns
    # the Node runtime, so this deployed copy is obsolete.
    rm -f "$HOME/bin/myshell-install-node-lts"
    # Clean up the old unnamespaced deploy from pre-rename installs —
    # but only if it's ours (the old file carried this exact comment, so
    # the match won't touch a user's personal ~/bin/update).
    if [ -f "$HOME/bin/update" ] && \
       grep -q 'Deployed to ~/bin/update during Converge' "$HOME/bin/update" 2>/dev/null; then
        rm -f "$HOME/bin/update"
    fi

    sublog "~/.config/starship.toml"
    mkdir -p "$HOME/.config"
    fetch_config https://github.com/enstw/myshell-starship/raw/refs/heads/master/starship.toml \
                 "$HOME/.config/starship.toml"

    sublog "eza tokyonight theme"
    local eza_dir
    if [[ "$OS" == macos ]]; then
        eza_dir="$HOME/Library/Application Support/eza"
    else
        eza_dir="$HOME/.config/eza"
    fi
    mkdir -p "$eza_dir"
    fetch_config https://raw.githubusercontent.com/eza-community/eza-themes/main/themes/tokyonight.yml \
                 "$eza_dir/theme.yml"
}
configure_git() {
    log "Configuring git identity..."
    local current_name current_email
    current_name=$(git config --global user.name  2>/dev/null || true)
    current_email=$(git config --global user.email 2>/dev/null || true)
    # Check-first: skip when the identity is complete, so re-runs stay
    # non-interactive. `git config --global` is the tool for changing it.
    if [[ -n "$current_name" && -n "$current_email" ]]; then
        sublog "already configured: $current_name <$current_email> — skipping"
        return 0
    fi
    # Answers come from gather_answers; ask here only if this step is somehow
    # reached without them (e.g. the user answered with empty strings).
    [[ -n "$GIT_NAME"  ]] || GIT_NAME=$(ask "git user.name?"  "$current_name")
    [[ -n "$GIT_EMAIL" ]] || GIT_EMAIL=$(ask "git user.email?" "$current_email")
    git config --global user.name  "$GIT_NAME"
    git config --global user.email "$GIT_EMAIL"
    sublog "$GIT_NAME <$GIT_EMAIL>"
}

configure_locale() {
    if [[ "$OS" != ubuntu ]]; then
        log "Locale generation..."
        sublog "macOS: system locales are available per-user, skipping locale-gen"
        return 0
    fi
    if [[ "$NO_SUDO" == "1" ]]; then
        log "Locale generation..."
        warn "no sudo — skipping locale-gen; ensure root has run: locale-gen en_US.UTF-8 en_GB.UTF-8 zh_TW.UTF-8"
        return 0
    fi
    log "Generating locales (en_US, en_GB, zh_TW — .UTF-8)..."
    # Idempotency: skip the slow sudo locale-gen/update-locale when the three
    # locales are already compiled and the system default already targets zh_TW.
    # `locale -a` normalizes names (e.g. en_US.utf8), so match dash/case-insensitively.
    local have
    have=$(locale -a 2>/dev/null | tr '[:upper:]' '[:lower:]' | tr -d '-')
    if grep -qx 'en_us.utf8' <<<"$have" \
       && grep -qx 'en_gb.utf8' <<<"$have" \
       && grep -qx 'zh_tw.utf8' <<<"$have" \
       && grep -q '^LANG=zh_TW.UTF-8' /etc/default/locale 2>/dev/null; then
        sublog "already generated and default set to zh_TW.UTF-8 — skipping"
        return 0
    fi
    if ! command -v locale-gen >/dev/null; then
        sublog "locale-gen missing; installing 'locales'..."
        $SUDO apt-get install -y locales
    fi
    $SUDO locale-gen en_US.UTF-8 en_GB.UTF-8 zh_TW.UTF-8 >/dev/null
    $SUDO update-locale LANG=zh_TW.UTF-8 LANGUAGE=zh_TW:en >/dev/null
    sublog "default LANG=zh_TW.UTF-8 LANGUAGE=zh_TW:en"
}

configure_timezone() {
    if [[ "$NO_SUDO" == "1" ]]; then
        log "Timezone..."
        warn "no sudo — skipping; ensure root has set timezone to Asia/Taipei"
        return 0
    fi
    log "Setting timezone to Asia/Taipei..."
    local target=Asia/Taipei current
    if [[ "$OS" == macos ]]; then
        # Read the zone without sudo (systemsetup -gettimezone needs admin, which
        # would make even an already-correct box prompt). /etc/localtime is a
        # symlink into .../zoneinfo/<Area>/<City>.
        current=$(readlink /etc/localtime 2>/dev/null || true)
        current="${current#*/zoneinfo/}"
        if [[ "$current" == "$target" ]]; then
            sublog "already $target"
            return 0
        fi
        $SUDO systemsetup -settimezone "$target" >/dev/null
    elif command -v timedatectl >/dev/null && timedatectl status >/dev/null 2>&1; then
        current=$(timedatectl show --property=Timezone --value 2>/dev/null || true)
        if [[ "$current" == "$target" ]]; then
            sublog "already $target"
            return 0
        fi
        $SUDO timedatectl set-timezone "$target"
    else
        # Container / no systemd: write /etc/timezone + relink /etc/localtime.
        current=$(cat /etc/timezone 2>/dev/null || true)
        if [[ "$current" == "$target" ]]; then
            sublog "already $target"
            return 0
        fi
        echo "$target" | $SUDO tee /etc/timezone >/dev/null
        $SUDO ln -sf "/usr/share/zoneinfo/$target" /etc/localtime
    fi
    sublog "set to $target"
}

setup_pnpm() {
    command -v pnpm >/dev/null || { log "pnpm setup"; warn "pnpm not found — skipping"; return 0; }
    log "Provisioning Node LTS via pnpm..."
    # Check-first: if pnpm already provisioned a Node runtime, skip the network
    # re-resolve. Bootstrap only guarantees a runtime exists; refreshing it to
    # the newest LTS is `myshell-update`'s job (the `u` alias).
    if command -v node >/dev/null 2>&1; then
        sublog "Node already provisioned ($(node --version)) — skipping; 'u' refreshes LTS"
        return 0
    fi
    # pnpm supplies the Node runtime that pnpm-global JS packages (Codex's
    # npm launcher) and general dev work need; this also lands node/npm/npx
    # symlinks in pnpm's global bin dir (already on PATH).
    if pnpm runtime set node lts -g; then
        sublog "Node LTS active ($(node --version 2>/dev/null || echo 'pending new shell'))"
    else
        warn "pnpm runtime set node lts failed; Codex may lack a node runtime"
    fi
}

# normalize_agent_choice RAW — echo the canonical comma-separated agent list
# (subset of claude,codex,opencode,agy) for a menu answer of numbers and/or
# names. Unknown tokens warn (stderr — stdout is captured by the caller) and
# are dropped; duplicates collapse.
normalize_agent_choice() {
    local raw="$1" token name names=()
    local -A seen=()
    case "$raw" in
        0|none|"") echo ""; return 0 ;;
    esac
    for token in ${raw//,/ }; do
        name=""
        case "$token" in
            5|all) echo "claude,codex,opencode,agy"; return 0 ;;
            1|claude|claude-code) name=claude ;;
            2|codex)              name=codex ;;
            3|opencode)           name=opencode ;;
            4|agy|antigravity)    name=agy ;;
            0|none) ;;
            *) warn "unknown agent '$token' (ignoring)" ;;
        esac
        [[ -z "$name" || -n "${seen[$name]:-}" ]] && continue
        seen[$name]=1
        names+=("$name")
    done
    (IFS=,; echo "${names[*]-}")
}

install_agents() {
    log "AI agents — Claude Code, Codex, OpenCode, Antigravity (agy)"
    # One menu for all four agents; "0 none" really means none (no follow-up
    # prompts). The recorded answer (normally gathered up front) is the
    # idempotency key — a partial or empty choice is honored on re-runs
    # instead of re-asking; it's NOT keyed on which binaries happen to be
    # installed. Each per-agent installer is still check-first.
    choose_agents
    local selected agent
    selected=$(<"$STATE_DIR/agents")
    if [[ -z "$selected" ]]; then
        sublog "no agents selected (rm $STATE_DIR/agents to re-choose) — skipping"
        return 0
    fi
    sublog "selected: $selected (rm $STATE_DIR/agents to re-choose)"
    for agent in ${selected//,/ }; do
        case "$agent" in
            claude)   install_agent "Claude Code"      install_claude_code ;;
            codex)    install_agent "OpenAI Codex CLI" install_codex ;;
            opencode) install_agent "OpenCode"         install_opencode ;;
            agy)      install_agent "Antigravity CLI"  install_agy ;;
            *)        warn "unknown agent '$agent' in $STATE_DIR/agents (skipping)" ;;
        esac
    done
}

install_opencode() {
    # OpenCode — standalone prebuilt binary (no npm/node) in ~/.opencode/bin,
    # installed like bun. Self-updates via `opencode upgrade`, so it stays out
    # of the pnpm global set (see the header's agent rule). No sudo; works
    # under NO_SUDO. Fail-soft via the install_agent wrapper.
    log "Installing OpenCode..."
    if [[ -x "$HOME/.opencode/bin/opencode" ]]; then
        sublog "already installed (~/.opencode/bin) — skipping"
        return 0
    fi
    sublog "opencode.ai installer (--no-modify-path; ~/.zshenv owns PATH)"
    # --no-modify-path: the installer would otherwise append PATH lines to
    # ~/.zshrc/~/.zshenv; our generated ~/.zshenv owns PATH (same as bun).
    curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path
}

install_agy() {
    # Antigravity CLI (agy) — Google's standalone Go binary, the replacement for
    # the retired Gemini CLI. Self-updating (`agy update`), node-free, no sudo.
    # Installs to ~/.local/bin/agy, which is already on PATH via ~/.zshenv — a
    # peer like opencode/bun, deliberately not a pnpm agent.
    log "Installing Antigravity CLI (agy)..."
    if command -v agy >/dev/null || [[ -x "$HOME/.local/bin/agy" ]]; then
        sublog "already installed ($(command -v agy 2>/dev/null || echo "$HOME/.local/bin/agy")) — skipping"
        return 0
    fi
    sublog "antigravity.google installer (binary -> ~/.local/bin/agy)"
    # The installer finishes by running `agy install` to configure PATH/aliases;
    # ~/.local/bin is already on our PATH, so that step is redundant but harmless.
    curl -fsSL https://antigravity.google/cli/install.sh | bash
}

npm_registry_ok() {
    sublog "checking npm registry reachability (registry.npmjs.org)"
    curl -fsSI https://registry.npmjs.org/ >/dev/null 2>&1
}

install_agent() {
    local label="$1"
    shift
    if "$@"; then
        return 0
    fi
    warn "$label install failed; continuing with the rest of bootstrap"
    return 0
}

install_claude_code() {
    # Claude Code — self-updates in place, so it's standalone-managed like
    # opencode/agy (native claude.ai installer -> ~/.local/bin/claude), NOT
    # pnpm: an auto-updater writing into a pnpm-owned tree fights pnpm, and
    # $PNPM_HOME precedes ~/.local/bin in PATH so a leftover pnpm copy from an
    # older bootstrap would shadow the native binary — migrate it out first
    # (config in ~/.claude is untouched; same pattern as the brew-pnpm purge).
    log "Installing Claude Code..."
    if pnpm ls -g --depth=0 2>/dev/null | grep -q '@anthropic-ai/claude-code'; then
        sublog "removing pnpm-managed copy in favor of the native install..."
        pnpm remove -g @anthropic-ai/claude-code || true
    fi
    if [[ -x "$HOME/.local/bin/claude" ]]; then
        sublog "already installed (~/.local/bin/claude) — skipping"
        return 0
    fi
    sublog "claude.ai installer (binary -> ~/.local/bin/claude)"
    curl -fsSL https://claude.ai/install.sh | bash
}

install_codex() {
    # Codex — a static binary delivered through npm with no self-updater, so
    # the pnpm global set is the right home (`pnpm update -g` in
    # myshell-update is its update path). The registry probe lives here, next
    # to the only agent that needs the npm registry.
    log "Installing OpenAI Codex CLI..."
    if pnpm ls -g --depth=0 2>/dev/null | grep -q '@openai/codex'; then
        sublog "already installed (pnpm global) — skipping"
        return 0
    fi
    command -v pnpm >/dev/null || { warn "pnpm not found — skipping (Codex installs via pnpm)"; return 0; }
    if ! npm_registry_ok; then
        warn "cannot reach the npm registry; retry later with: pnpm add -g @openai/codex"
        return 0
    fi
    sublog "pnpm add -g @openai/codex"
    pnpm add -g @openai/codex
}

configure_tealdeer() {
    command -v tldr >/dev/null || { log "tealdeer config"; warn "tldr not found — skipping"; return 0; }
    log "Configuring tealdeer (auto-update, zh_TW + en pages)..."
    local config_dir
    if [[ "$OS" == macos ]]; then
        config_dir="$HOME/Library/Application Support/tealdeer"
    else
        config_dir="$HOME/.config/tealdeer"
    fi
    mkdir -p "$config_dir"
    # Language preference is controlled by LANGUAGE=zh_TW:en in ~/.zshenv;
    # tealdeer honors it at lookup time.
    cat >"$config_dir/config.toml" <<'EOF'
# Generated by myshell/scripts/install.
# Page language is picked from $LANGUAGE (set to zh_TW:en in ~/.zshenv).

[updates]
auto_update = true
auto_update_interval_hours = 720
EOF
    # Check-first: only fetch the page cache when it's missing. Once present,
    # auto_update (configured above) keeps it fresh — no network on re-runs.
    local cache_dir
    if [[ "$OS" == macos ]]; then
        cache_dir="$HOME/Library/Caches/tealdeer/tldr-pages"
    else
        cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/tealdeer/tldr-pages"
    fi
    if [[ -d "$cache_dir" ]]; then
        sublog "page cache present — auto_update keeps it fresh, skipping fetch"
        return 0
    fi
    sublog "fetching page cache (LANGUAGE=zh_TW:en)..."
    if ! LANGUAGE=zh_TW:en tldr --update >/dev/null 2>&1; then
        warn "tldr --update failed; will retry on first use"
    fi
}

ens_fonts_dir() {
    if [[ "$OS" == macos ]]; then
        echo "$HOME/Library/Fonts"
    else
        echo "$HOME/.local/share/fonts"
    fi
}

install_fonts() {
    # ENSFont.ttc is published as the single asset on the latest release of
    # github.com/enstw/font. GitHub's /releases/latest/download/<name> URL is
    # a stable redirect to that asset, so no jq/tarball dance is needed.
    local fonts_dir
    fonts_dir=$(ens_fonts_dir)
    # Check-first: an installed font wins; otherwise the recorded answer
    # (gathered up front) decides — a "no" is remembered across re-runs.
    if [[ -f "$fonts_dir/ENSFont.ttc" ]]; then
        log "ENS fonts already installed ($fonts_dir/ENSFont.ttc) — skipping"
        return 0
    fi
    choose_fonts
    if [[ "$(<"$STATE_DIR/fonts")" != yes ]]; then
        log "ENS fonts — declined (rm $STATE_DIR/fonts to be asked again)"
        return 0
    fi
    log "Installing ENS fonts..."
    mkdir -p "$fonts_dir"
    sublog "Downloading ENSFont.ttc (latest release)..."
    if ! curl -fsSL -o "$fonts_dir/ENSFont.ttc" \
        https://github.com/enstw/font/releases/latest/download/ENSFont.ttc; then
        warn "ENSFont.ttc download failed — skipping (re-run to retry)"
        return 0
    fi
    if [[ "$OS" == ubuntu ]] && command -v fc-cache >/dev/null; then
        fc-cache -f >/dev/null
    fi
}

configure_terminal_profile() {
    if [[ "$OS" != macos ]]; then
        return 0
    fi
    local profile_path="$REPO_ROOT/assets/tokyo-night.terminal"
    if [[ ! -f "$profile_path" ]]; then
        warn "Terminal profile $profile_path not found — skipping"
        return 0
    fi
    log "Configuring Terminal profile..."
    # Check-first: re-running `open` spawns a Terminal window every time, so
    # skip when tokyo-night is already the default.
    if [[ "$(defaults read com.apple.Terminal 'Default Window Settings' 2>/dev/null)" == "tokyo-night" ]]; then
        sublog "already default — skipping"
        return 0
    fi
    sublog "Installing tokyo-night profile..."
    # Open the profile to import it into Terminal
    open "$profile_path"
    # Allow a brief moment for it to be registered
    sleep 1
    sublog "Setting tokyo-night as default..."
    defaults write com.apple.Terminal "Default Window Settings" -string "tokyo-night"
    defaults write com.apple.Terminal "Startup Window Settings" -string "tokyo-night"
}

# Check the passwd entry, not $SHELL: the env var is frozen at session
# start, so after a chsh it still shows the old shell and a same-session
# re-run would re-prompt.
current_login_shell() {
    if [[ "$OS" == macos ]]; then
        dscl . -read "/Users/$(id -un)" UserShell 2>/dev/null | awk '{print $2}' || true
    else
        getent passwd "$(id -un)" 2>/dev/null | cut -d: -f7 || true
    fi
}

set_login_shell() {
    log "Login shell..."
    local zsh_path current_shell
    zsh_path=$(command -v zsh || true)
    [[ -z "$zsh_path" ]] && { warn "zsh not found — skipping"; return 0; }
    current_shell=$(current_login_shell)
    # Basename match, not exact path: /bin/zsh vs the brew zsh is still zsh —
    # don't churn the passwd entry (or re-ask) over a path difference. This
    # also guarantees the choice file exists after choose_login_shell below
    # (its only no-record path is the already-zsh one handled here).
    if [[ "${current_shell:-${SHELL:-}}" == */zsh || "${current_shell:-${SHELL:-}}" == zsh ]]; then
        sublog "already zsh (${current_shell:-$SHELL})"
        return 0
    fi
    choose_login_shell
    if [[ "$(<"$STATE_DIR/login-shell")" != yes ]]; then
        sublog "declined (rm $STATE_DIR/login-shell to be asked again)"
        return 0
    fi
    if ! grep -qx "$zsh_path" /etc/shells 2>/dev/null; then
        if [[ "$NO_SUDO" == "1" ]]; then
            warn "no sudo — $zsh_path not in /etc/shells; ask root to add it before chsh"
            return 0
        fi
        sublog "Adding $zsh_path to /etc/shells..."
        echo "$zsh_path" | $SUDO tee -a /etc/shells >/dev/null
    fi
    sublog "chsh -s $zsh_path (may prompt for your password)"
    chsh -s "$zsh_path"
}

main() {
    log "myshell stage 2 — $OS"
    # All prompts live in gather_answers (see the header rule) so the long
    # package phase runs unattended; answers are recorded under $STATE_DIR.
    gather_answers
    # Locale first: apt maintainer scripts shell out to perl with
    # LANG=zh_TW.UTF-8 inherited from the caller's env. If that locale
    # hasn't been generated yet, every subsequent apt install prints
    # `perl: warning: Setting locale failed`. Generating locales before
    # any package work silences the warnings.
    configure_locale
    install_apps
    # Purge before unminimize so we don't reinstall docs for packages we're
    # about to remove.
    purge_conflicts
    # After install_apps: unminimize reinstalls docs for everything already
    # installed, so base packages added above still end up with man pages.
    unminimize_ubuntu
    deploy_dotfiles
    deploy_scripts
    configure_git
    configure_timezone
    setup_pnpm
    install_agents
    configure_tealdeer
    install_fonts
    configure_terminal_profile
    set_login_shell
    if [[ "$WARNINGS" -gt 0 ]]; then
        log "Done with $WARNINGS warning(s) — grep output for 'warning:'. Start a new shell to pick up changes."
    else
        log "Done. Start a new shell to pick up changes."
    fi
}

main "$@"

