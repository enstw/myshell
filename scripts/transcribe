#!/usr/bin/env bash
set -euo pipefail

VENV="$HOME/tools/faster-whisper/venv"
MODEL="${WHISPER_MODEL:-large-v3-turbo}"

if [ $# -lt 1 ]; then
    echo "Usage: $0 <youtube-url|audio-file> [output-dir]"
    exit 1
fi

SOURCE="$1"
OUTDIR="$(cd "${2:-.}" && pwd)"

# If source is a local file, transcribe directly
if [ -f "$SOURCE" ]; then
    BASENAME="$(basename "$SOURCE" | sed 's/\.[^.]*$//')"
    OUTPUT="$OUTDIR/${BASENAME}.txt"
    echo "Transcribing..."
    "$VENV/bin/python" -c "
import sys
from faster_whisper import WhisperModel
model = WhisperModel('$MODEL', device='cpu', compute_type='int8')
segments, info = model.transcribe('$SOURCE', vad_filter=True)
print(f'Audio duration: {info.duration:.1f}s', file=sys.stderr)
with open('$OUTPUT', 'w') as f:
    for s in segments:
        pct = s.end / info.duration * 100
        print(f'  [{s.start:.1f}s -> {s.end:.1f}s] ({pct:.0f}%) {s.text.strip()}', file=sys.stderr)
        f.write(s.text.strip() + '\n')
"
    echo "Done: $OUTPUT"
    exit 0
fi

# Otherwise treat as URL and download
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

echo "Downloading audio..."
yt-dlp -x --audio-format wav \
    --js-runtimes node \
    --remote-components ejs:github \
    --postprocessor-args "ffmpeg:-ar 16000 -ac 1" \
    -o "$TMPDIR/%(title)s.%(ext)s" \
    "$SOURCE"

WAV="$(find "$TMPDIR" -name '*.wav' | head -1)"
if [ -z "$WAV" ]; then
    echo "Error: no WAV file produced"
    exit 1
fi

BASENAME="$(basename "$WAV" .wav)"
OUTPUT="$OUTDIR/${BASENAME}.txt"

echo "Transcribing..."
"$VENV/bin/python" -c "
import sys
from faster_whisper import WhisperModel
model = WhisperModel('$MODEL', device='cpu', compute_type='int8')
segments, info = model.transcribe('$WAV', vad_filter=True)
print(f'Audio duration: {info.duration:.1f}s', file=sys.stderr)
with open('$OUTPUT', 'w') as f:
    for s in segments:
        pct = s.end / info.duration * 100
        print(f'  [{s.start:.1f}s -> {s.end:.1f}s] ({pct:.0f}%) {s.text.strip()}', file=sys.stderr)
        f.write(s.text.strip() + '\n')
"

echo "Done: $OUTPUT"
