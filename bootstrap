#!/bin/sh
set -eu

# myshell bootstrap — POSIX-sh stage 1.
# Installs brew + modern bash (macOS) or refreshes apt (Ubuntu),
# then hands off to the bash 5 installer.

log() { printf '==> %s\n' "$*"; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }

detect_os() {
    case "$(uname -s)" in
        Darwin) echo macos ;;
        Linux)
            [ -r /etc/os-release ] || die "cannot detect Linux distribution"
            # shellcheck disable=SC1091
            . /etc/os-release
            case "${ID:-}" in
                ubuntu|debian) echo ubuntu ;;
                *) die "unsupported Linux distribution: ${ID:-unknown}" ;;
            esac
            ;;
        *) die "unsupported platform: $(uname -s)" ;;
    esac
}

brew_prefix() {
    case "$(uname -m)" in
        arm64) echo /opt/homebrew ;;
        x86_64) echo /usr/local ;;
        *) die "unsupported macOS architecture: $(uname -m)" ;;
    esac
}

install_macos() {
    log "macOS detected."
    if ! command -v brew >/dev/null 2>&1; then
        log "Installing Homebrew — may prompt for password and open a Command Line Tools dialog."
        NONINTERACTIVE=1 /bin/bash -c \
            "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
    eval "$("$(brew_prefix)/bin/brew" shellenv)"
    if ! brew list --formula bash >/dev/null 2>&1; then
        log "Installing bash 5..."
        brew install bash
    fi
    BASH5="$(brew --prefix)/bin/bash"
}

install_ubuntu() {
    log "Ubuntu detected."
    log "Refreshing apt index (may prompt for sudo password)..."
    sudo apt-get update
    # Ubuntu 20.04+ ships bash 5 by default.
    BASH5=/bin/bash
}

main() {
    os=$(detect_os)
    case "$os" in
        macos)  install_macos ;;
        ubuntu) install_ubuntu ;;
    esac
    log "Stage 1 complete. Handing off to stage 2 (bash 5: $BASH5)..."
    stage2="$(dirname "$0")/scripts/install"
    # -f not -x: we invoke it via $BASH5, so the exec bit doesn't matter, and
    # tarball extracts / rsync without -p / core.fileMode=false can drop it.
    [ -f "$stage2" ] || die "stage 2 installer missing: $stage2"
    exec "$BASH5" "$stage2" "$@"
}

main "$@"
