#!/bin/sh
set -eu

# myshell bootstrap — POSIX-sh stage 1.
# Installs brew + modern bash (macOS) or refreshes apt (Ubuntu),
# then hands off to the bash 5 installer.
#
# Two entry paths:
#   1. from a checkout: ./bootstrap — uses the sibling scripts/install.
#   2. piped: `curl -fsSL .../bootstrap | sh` — fetches the latest repo
#      tarball into a tmp dir, runs stage 2 from there, cleans up after.

REPO_TARBALL="https://github.com/enstw/myshell/archive/refs/heads/main.tar.gz"

log() { printf '==> %s\n' "$*"; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }

detect_os() {
    case "$(uname -s)" in
        Darwin) echo macos ;;
        Linux)
            [ -r /etc/os-release ] || die "cannot detect Linux distribution"
            # shellcheck disable=SC1091
            . /etc/os-release
            case "${ID:-}" in
                ubuntu|debian) echo ubuntu ;;
                *) die "unsupported Linux distribution: ${ID:-unknown}" ;;
            esac
            ;;
        *) die "unsupported platform: $(uname -s)" ;;
    esac
}

brew_prefix() {
    case "$(uname -m)" in
        arm64) echo /opt/homebrew ;;
        x86_64) echo /usr/local ;;
        *) die "unsupported macOS architecture: $(uname -m)" ;;
    esac
}

install_macos() {
    log "macOS detected."
    # `command -v brew` only finds it once PATH is set up. On a fresh shell
    # immediately after the Homebrew installer runs, brew is on disk but not
    # yet in PATH — fall back to the known prefix paths so we don't reinstall.
    brew_bin=""
    if command -v brew >/dev/null 2>&1; then
        brew_bin=$(command -v brew)
    elif [ -x /opt/homebrew/bin/brew ]; then
        brew_bin=/opt/homebrew/bin/brew
    elif [ -x /usr/local/bin/brew ]; then
        brew_bin=/usr/local/bin/brew
    fi

    if [ -z "$brew_bin" ]; then
        log "Installing Homebrew — may prompt for password and open a Command Line Tools dialog."
        NONINTERACTIVE=1 /bin/bash -c \
            "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        brew_bin="$(brew_prefix)/bin/brew"
    else
        log "Homebrew already installed ($brew_bin) — skipping."
    fi
    eval "$("$brew_bin" shellenv)"
    if ! brew list --formula bash >/dev/null 2>&1; then
        log "Installing bash 5..."
        brew install bash
    else
        log "bash 5 already installed — skipping."
    fi
    BASH5="$(brew --prefix)/bin/bash"
}

install_ubuntu() {
    log "Ubuntu detected."
    log "Refreshing apt index (may prompt for sudo password)..."
    sudo apt-get update
    # Ubuntu 20.04+ ships bash 5 by default.
    BASH5=/bin/bash
}

main() {
    os=$(detect_os)
    case "$os" in
        macos)  install_macos ;;
        ubuntu) install_ubuntu ;;
    esac

    # Prefer a sibling scripts/install (local checkout) so dev iteration
    # works. Fall back to downloading the latest tarball into a tmp dir —
    # this is the curl|sh path and also the "tarball without exec bit" path.
    # -f not -x: stage 2 is invoked via $BASH5, so the exec bit is optional.
    stage2="$(dirname "$0")/scripts/install"
    if [ ! -f "$stage2" ]; then
        log "No local scripts/install — fetching latest tarball..."
        tmp=$(mktemp -d)
        # Trap (not exec) handoff: we need the tmp dir to survive stage 2,
        # and to be removed whether stage 2 succeeds, fails, or is Ctrl-C'd.
        trap 'rm -rf "$tmp"' EXIT INT TERM
        curl -fsSL "$REPO_TARBALL" | tar xz -C "$tmp"
        stage2="$tmp/myshell-main/scripts/install"
        [ -f "$stage2" ] || die "stage 2 installer missing after download: $stage2"
    fi

    log "Stage 1 complete. Handing off to stage 2 (bash 5: $BASH5)..."
    "$BASH5" "$stage2" "$@"
}

main "$@"
